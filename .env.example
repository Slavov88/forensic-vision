# ── Django ────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production-use-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database (PostgreSQL) ──────────────────────────────────────────────────────
DB_NAME=forensicvision
DB_USER=forensicvision
DB_PASSWORD=forensicvision
DB_HOST=db
DB_PORT=5432

# ── Redis / Celery ─────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── File uploads ───────────────────────────────────────────────────────────────
MAX_UPLOAD_MB=25

# ── Token auth (DRF) ──────────────────────────────────────────────────────────
# TokenAuthentication is enabled by default for API testing via curl
